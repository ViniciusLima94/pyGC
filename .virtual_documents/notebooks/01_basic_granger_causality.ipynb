


import numpy as np
import matplotlib.pyplot as plt

from pygc.ar_model import ar_model_dhamala
from pygc.parametric import YuleWalker, compute_transfer_function
from pygc.non_parametric import wilson_factorization
from pygc.granger import granger_causality
from pygc.spectral_analysis.fourier import compute_freq, csd_fourier

plt.rcParams.update({'figure.dpi': 100, 'font.size': 12})





np.random.seed(42)

Fs     = 200     # sampling rate (Hz)
N      = 5000    # samples per trial
Trials = 1000      # number of independent trials
C      = 0.25    # coupling strength Y -> X

cov = np.array([[0.5, 0.0],
                [0.0, 0.5]])

Z = ar_model_dhamala(N=N, Trials=Trials, Fs=Fs, C=C,
                     t_start=0, t_stop=None, cov=cov)
# Z shape: (2, Trials, N)
print('Data shape (channels, trials, samples):', Z.shape)

fig, axes = plt.subplots(2, 1, figsize=(12, 4), sharex=True)
t = np.arange(N) / Fs
axes[0].plot(t[:500], Z[0, 0, :500], lw=0.8)
axes[0].set_ylabel('X')
axes[1].plot(t[:500], Z[1, 0, :500], lw=0.8, color='C1')
axes[1].set_ylabel('Y')
axes[1].set_xlabel('Time (s)')
fig.suptitle('Simulated bivariate AR signal (first 2.5 s, trial 0)')
plt.tight_layout()





# Concatenate trials into one long time series
X_all = Z.reshape(2, Trials * N)  # (2, Trials*N)

model_order = 10
AR, sigma = YuleWalker(X_all, model_order)

print('AR coefficient shape:', AR.shape)
print('Noise covariance:\n', sigma)


# Frequency axis
f = np.linspace(1, Fs / 2 - 1, 200)

H, S = compute_transfer_function(AR, sigma, f, Fs)

# Granger causality
Ix2y_param, Iy2x_param, Ixy_param = granger_causality(S, H, sigma)

print(f'Mean GC(Y->X) = {Ix2y_param.mean():.4f}')
print(f'Mean GC(X->Y) = {Iy2x_param.mean():.4f}')





freq = compute_freq(N, Fs)

# Build 2x2 cross-spectral matrix averaged over trials
S_np = np.zeros([2, 2, len(freq)], dtype=complex)
for trial in range(Trials):
    for i in range(2):
        for j in range(2):
            S_np[i, j] += csd_fourier(Z[i, trial], Y=Z[j, trial], f=freq, Fs=Fs)
S_np /= Trials

print('Spectral matrix shape:', S_np.shape)


Snew, Hnew, Znew = wilson_factorization(S_np, freq, Fs, Niterations=200, tol=1e-12, verbose=False)

Ix2y_np, Iy2x_np, Ixy_np = granger_causality(Snew, Hnew, Znew)

print(f'Mean GC(Y->X) = {Ix2y_np.mean():.4f}')
print(f'Mean GC(X->Y) = {Iy2x_np.mean():.4f}')





fig, axes = plt.subplots(1, 2, figsize=(14, 4), sharey=True)

# Parametric
axes[0].plot(f, Ix2y_param, label='GC(Y→X)', lw=2)
axes[0].plot(f, Iy2x_param, label='GC(X→Y)', lw=2, linestyle='--')
axes[0].set_title('Parametric (Yule-Walker)')
axes[0].set_xlabel('Frequency (Hz)')
axes[0].set_ylabel('Granger Causality')
axes[0].legend()
axes[0].set_xlim([0, 100])

# Non-parametric
axes[1].plot(freq, Ix2y_np, label='GC(Y→X)', lw=2)
axes[1].plot(freq, Iy2x_np, label='GC(X→Y)', lw=2, linestyle='--')
axes[1].set_title('Non-parametric (Wilson Factorization)')
axes[1].set_xlabel('Frequency (Hz)')
axes[1].legend()
axes[1].set_xlim([0, 100])

fig.suptitle(f'Granger Causality — Dhamala AR model (C={C}, Y drives X)')
plt.tight_layout()



