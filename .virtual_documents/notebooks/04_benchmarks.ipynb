


import math
import time
import warnings
from collections import defaultdict

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from scipy import signal as sp_signal

warnings.filterwarnings('ignore')

from pygc import (
    YuleWalker, compute_transfer_function,
    wilson_factorization, wilson_factorization_jax,
    granger_causality, JAX_AVAILABLE, JAX_FLOAT64,
)
from pygc.spectral_analysis.fourier import compute_freq, csd_fourier, morlet_transform
from pygc.spectral_analysis.time_frequency import welch_spectrum

plt.rcParams.update({'figure.dpi': 100, 'font.size': 12})

# ── Configuration ────────────────────────────────────────────────────────────
Fs        = 200                            # sampling rate (Hz)
AR_ORDER  = 10                             # Yule-Walker model order
N_REPEATS = 3                              # timed repetitions (median)
N_VALUES  = [256, 512, 1024, 2048, 4096] # data sizes to sweep
N_CYCLES  = 7.0                            # Morlet wavelet cycles

# MNE Morlet kernel length ≈ 10 * n_cycles / (2π * f) * Fs.
# The kernel must be shorter than the smallest N in N_VALUES, so:
#   f_min > 10 * n_cycles * Fs / (2π * N_min)
_f_min = math.ceil(10 * N_CYCLES * Fs / (2 * math.pi * min(N_VALUES))) + 1
MORLET_FREQS = np.linspace(_f_min, Fs / 2 - 1, 80)  # fixed 80-freq Morlet grid
print(f"Morlet freq range: {MORLET_FREQS[0]:.1f} – {MORLET_FREQS[-1]:.1f} Hz  ({len(MORLET_FREQS)} bins)")





from pygc import JAX_AVAILABLE, JAX_FLOAT64

if JAX_AVAILABLE:
    import jax
    devices   = jax.devices()
    platform  = jax.default_backend()
    precision = "complex128 (float64)" if JAX_FLOAT64 else "complex64 (float32)"
    print(f"JAX {jax.__version__}")
    print(f"  platform : {platform}")
    print(f"  devices  : {devices}")
    print(f"  precision: {precision}")
    if not JAX_FLOAT64:
        print("\n  ⚠  Metal GPU detected — running in float32 (lower precision, faster).")
    print("\nJAX benchmarks will be included.")
else:
    print("JAX not installed — JAX benchmarks skipped.")
    print()
    print("Install options:")
    print("  CPU / NVIDIA:       pip install jax")
    print("  Apple Silicon GPU:  pip install jax-metal")





# ── Data ─────────────────────────────────────────────────────────────────────

def make_data(N, seed=0):
    """2-channel white Gaussian noise, shape (2, N)."""
    return np.random.default_rng(seed).standard_normal((2, N))


# ── Timing utility ────────────────────────────────────────────────────────────

def time_fn(fn, n=N_REPEATS):
    """Median wall-clock time (s) over n calls."""
    t = []
    for _ in range(n):
        t0 = time.perf_counter()
        fn()
        t.append(time.perf_counter() - t0)
    return float(np.median(t))


# ── CSD builders (return S of shape (2, 2, n_freq) and freq axis) ─────────────

def build_S_fft(data):
    """FFT periodogram CSD.
    n_freq = N//2 + 1 — scales with N.
    """
    x, y = data[0], data[1]
    f = compute_freq(len(x), Fs)
    S = np.zeros((2, 2, len(f)), dtype=complex)
    S[0, 0] = csd_fourier(x, x, f, Fs)
    S[0, 1] = csd_fourier(x, y, f, Fs)
    S[1, 0] = np.conj(S[0, 1])
    S[1, 1] = csd_fourier(y, y, f, Fs)
    return S, f


def build_S_welch(data):
    """Welch-averaged CSD via scipy.signal (default nperseg=256).
    n_freq = nperseg//2 + 1 = 129 — independent of N for N >= 256.
    """
    S = welch_spectrum(data[np.newaxis], fs=Fs)      # (2, 2, n_freq)
    f, _ = sp_signal.csd(data[0], data[0], Fs)      # probe matching freq axis
    return S, f


def build_S_morlet(data):
    """Morlet-wavelet CSD, time-averaged.
    n_freq = len(MORLET_FREQS) = 80 — independent of N.
    """
    x, y = data[0], data[1]
    N = len(x)
    Wx = morlet_transform(x, MORLET_FREQS, Fs, n_cycles=N_CYCLES)   # (N, 80)
    Wy = morlet_transform(y, MORLET_FREQS, Fs, n_cycles=N_CYCLES)
    S = np.zeros((2, 2, len(MORLET_FREQS)), dtype=complex)
    S[0, 0] = (Wx * np.conj(Wx) / N).mean(axis=0)
    S[0, 1] = (Wx * np.conj(Wy) / N).mean(axis=0)
    S[1, 0] = np.conj(S[0, 1])
    S[1, 1] = (Wy * np.conj(Wy) / N).mean(axis=0)
    return S, MORLET_FREQS


# ── GC pipeline runners ───────────────────────────────────────────────────────

def run_numpy(S, f):
    """Wilson (NumPy) + GC."""
    return granger_causality(S, f, Fs, method='wilson', verbose=False)


def run_jax(S, f):
    """Wilson (JAX JIT) + GC."""
    return granger_causality(S, f, Fs, method='jax')


def run_parametric(data):
    """Yule-Walker CSD + Wilson GC."""
    f = compute_freq(data.shape[1], Fs)
    AR, sigma = YuleWalker(data, AR_ORDER)
    _, S = compute_transfer_function(AR, sigma, f, Fs)
    return granger_causality(S, f, Fs, method='wilson', verbose=False)


print("Helpers defined.")





BUILDERS = [
    ("FFT",    build_S_fft),
    ("Welch",  build_S_welch),
    ("Morlet", build_S_morlet),
]

results = defaultdict(dict)   # results[label][N] = time_s

for N in N_VALUES:
    data = make_data(N)
    print(f"N = {N:5d}  ", end="", flush=True)

    # Parametric — no Wilson step
    results["Parametric"][N] = time_fn(lambda d=data: run_parametric(d))
    print("param", end=" ", flush=True)

    # NumPy Wilson
    for csd_name, build_fn in BUILDERS:
        results[f"{csd_name} + NumPy"][N] = time_fn(
            lambda b=build_fn, d=data: run_numpy(*b(d))
        )
    print("numpy", end=" ", flush=True)

    # JAX Wilson — warm up JIT for this freq_len, then time
    if JAX_AVAILABLE:
        for _, build_fn in BUILDERS:
            S_w, f_w = build_fn(data)
            run_jax(S_w, f_w)                 # compilation warmup

        for csd_name, build_fn in BUILDERS:
            results[f"{csd_name} + JAX"][N] = time_fn(
                lambda b=build_fn, d=data: run_jax(*b(d))
            )
        print("jax", end=" ", flush=True)

    print("✓")

print("\nBenchmark complete.")





df = pd.DataFrame(results).T
df.columns.name = "N"
df.index.name   = "Method"
df_ms = (df * 1000).round(1)
df_ms.columns = [f"N={n}" for n in df_ms.columns]

print("Median wall-clock time (ms)\n")
print(df_ms.to_string())


COLORS = {"FFT": "C0", "Welch": "C1", "Morlet": "C2", "Parametric": "C3"}
LS     = {"NumPy": "-",  "JAX":   "--"}
MK     = {"NumPy": "o",  "JAX":   "s"}

fig, ax = plt.subplots(figsize=(10, 5))

for label, times in results.items():
    Ns = sorted(times)
    ts = [times[n] * 1000 for n in Ns]
    if " + " in label:
        csd, backend = label.split(" + ")
        kw = dict(color=COLORS[csd], linestyle=LS[backend],
                  marker=MK[backend], lw=2, markersize=7, label=label)
    else:
        kw = dict(color=COLORS[label], linestyle=":",
                  marker="^", lw=2, markersize=7, label=label)
    ax.plot(Ns, ts, **kw)

ax.set_xscale("log", base=2)
ax.set_yscale("log")
ax.set_xticks(N_VALUES)
ax.set_xticklabels(N_VALUES)
ax.set_xlabel("N (time samples)")
ax.set_ylabel("Wall-clock time (ms)")
ax.set_title(
    f"Spectral GC — total pipeline time vs. data size\n"
    f"(2-ch Gaussian noise, Fs={Fs} Hz, {N_REPEATS} repeats)"
)
ax.legend(ncol=2, fontsize=10)
ax.grid(True, which="both", alpha=0.3)
plt.tight_layout()
plt.show()





N_BD    = 2048
data_bd = make_data(N_BD)

csd_t      = {}
w_np_t     = {}
w_jax_t    = {}
n_freq_bd  = {}

for csd_name, build_fn in BUILDERS:
    # CSD timing
    csd_t[csd_name] = time_fn(lambda b=build_fn, d=data_bd: b(d))

    # Wilson timing using pre-built S (CSD cost not double-counted)
    S_bd, f_bd = build_fn(data_bd)
    n_freq_bd[csd_name] = S_bd.shape[2]

    w_np_t[csd_name] = time_fn(
        lambda s=S_bd, f=f_bd: wilson_factorization(s, f, Fs, verbose=False)
    )
    if JAX_AVAILABLE:
        w_jax_t[csd_name] = time_fn(
            lambda s=S_bd, f=f_bd: wilson_factorization_jax(s, f, Fs)
        )

# Parametric breakdown
AR_bd, sigma_bd = YuleWalker(data_bd, AR_ORDER)
f_param_bd      = compute_freq(N_BD, Fs)
ar_t = time_fn(lambda d=data_bd: YuleWalker(d, AR_ORDER))
tf_t = time_fn(lambda: compute_transfer_function(AR_bd, sigma_bd, f_param_bd, Fs))

print(f"Frequency grid sizes fed to Wilson (N={N_BD}):")
for m, nb in n_freq_bd.items():
    print(f"  {m:8s}: {nb} bins")
print(f"  Param   : {len(f_param_bd)} bins (same as FFT)")


groups = [csd_name for csd_name, _ in BUILDERS]  # ["FFT", "Welch", "Morlet"]
x      = np.arange(len(groups))
w_bar  = 0.35

if JAX_AVAILABLE:
    x_np  = x - w_bar / 2
    x_jax = x + w_bar / 2
else:
    x_np  = x

fig, axes = plt.subplots(1, 2, figsize=(13, 5))

# ── Left: CSD computation time ──────────────────────────────────────────────
ax0 = axes[0]
csd_ms = np.array([csd_t[m] * 1000 for m in groups])
ax0.bar(x, csd_ms, 0.5, color=["C0", "C1", "C2"])
for xi, (m, ms) in enumerate(zip(groups, csd_ms)):
    ax0.text(xi, ms + 0.2, f"{ms:.1f} ms", ha="center", va="bottom", fontsize=9)
ax0.set_xticks(x)
ax0.set_xticklabels(groups)
ax0.set_ylabel("Time (ms)")
ax0.set_title(f"CSD computation time  (N={N_BD})")
ax0.grid(True, axis="y", alpha=0.3)

# ── Right: Wilson / AR time ──────────────────────────────────────────────────
ax1 = axes[1]
np_ms = np.array([w_np_t[m] * 1000 for m in groups])
ax1.bar(x_np, np_ms, w_bar, color="steelblue", label="Wilson (NumPy)")

for xi, (m, ms) in enumerate(zip(groups, np_ms)):
    pos = x_np[xi] if hasattr(x_np, '__len__') else x_np
    ax1.text(pos, ms + 0.2, f"{ms:.1f}", ha="center", va="bottom", fontsize=8)

if JAX_AVAILABLE:
    jax_ms = np.array([w_jax_t[m] * 1000 for m in groups])
    ax1.bar(x_jax, jax_ms, w_bar, color="darkorange", label="Wilson (JAX)")
    for xi, (m, ms) in enumerate(zip(groups, jax_ms)):
        ax1.text(x_jax[xi], ms + 0.2, f"{ms:.1f}", ha="center", va="bottom", fontsize=8)

# Parametric bar (AR fit + transfer fn stacked)
x_param = len(groups) + 0.6
ax1.bar(x_param, ar_t * 1000,               w_bar, color="C3",         label="YW (AR fit)")
ax1.bar(x_param, tf_t * 1000, bottom=ar_t * 1000, w_bar, color="C3", alpha=0.45, label="Transfer fn")
ax1.text(x_param, (ar_t + tf_t) * 1000 + 0.2,
         f"{(ar_t+tf_t)*1000:.1f}", ha="center", va="bottom", fontsize=8)

x_ticks = list(range(len(groups))) + [x_param]
ax1.set_xticks(x_ticks)
ax1.set_xticklabels(
    [f"{m}\n({n_freq_bd[m]} bins)" for m in groups]
    + [f"Parametric\n({len(f_param_bd)} bins)"]
)
ax1.set_ylabel("Time (ms)")
ax1.set_title(f"Wilson / AR time  (N={N_BD}, bin count in parentheses)")
ax1.legend(fontsize=9)
ax1.grid(True, axis="y", alpha=0.3)

fig.suptitle(f"Pipeline stage breakdown — N={N_BD}, Fs={Fs} Hz", fontsize=13)
plt.tight_layout()
plt.show()
